{# Ticker strip — top of every page. Clock is filled in by site.js. #}

<div class="ticker-strip" id="ticker">
  <span class="ticker-live"><span class="ticker-dot"></span>Now booking</span>
  <span class="ticker-div">·</span>
  <span>Same-week availability across Calgary, AB</span>
  <span class="ticker-div">·</span>
  <span><a href="mailto:{{ site.email }}">{{ site.email }}</a></span>
  <span class="ticker-div">·</span>
  <span id="ticker-clock">--:-- MT</span>
</div>
