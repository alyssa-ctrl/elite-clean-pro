<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#F1F1F1">

<title>{{ title }}</title>
<meta name="description" content="{{ description }}">

{# Canonical URL — uses page.url so each page gets its own #}
<link rel="canonical" href="{{ site.url }}{{ page.url }}">

{# Open Graph / Twitter — fall back to defaults if a page doesn't override #}
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:locale" content="en_CA">
<meta property="og:type" content="{{ ogType or 'website' }}">
<meta property="og:title" content="{{ ogTitle or title }}">
<meta property="og:description" content="{{ ogDescription or description }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:image" content="{{ site.url }}{{ ogImage or '/og-image.jpg' }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ ogTitle or title }}">
<meta name="twitter:description" content="{{ ogDescription or description }}">
<meta name="twitter:image" content="{{ site.url }}{{ ogImage or '/og-image.jpg' }}">

{# Favicon — small inline SVG #}
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='4' fill='%230A0E12'/><text y='24' x='4' font-size='22' font-family='Georgia,serif' fill='%2300A88B'>e</text></svg>">
<link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='4' fill='%230A0E12'/><text y='24' x='4' font-size='22' font-family='Georgia,serif' fill='%2300A88B'>e</text></svg>">

{# Google Fonts — Cormorant + Bricolage Grotesque + JetBrains Mono #}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300..700&family=Cormorant:ital,wght@0,300..700;1,300..700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

{# Shared site CSS — single source of truth #}
<link rel="stylesheet" href="/assets/site.css">

{# Page-specific extra head content (JSON-LD, page CSS, etc) #}
{% block head %}{% endblock %}
{{ extraHead | safe }}
</head>
<body>

<a href="#main" class="skip-link">Skip to content</a>

{% include "partials/ticker.njk" %}
{% include "partials/header.njk" %}

<main id="main">
{{ content | safe }}
</main>

{% include "partials/footer.njk" %}

{# Shared site JS — mobile menu, clock, scroll handler #}
<script src="/assets/site.js" defer></script>

{# Page-specific extra scripts #}
{{ extraScripts | safe }}

</body>
</html>
