/* ════════ MOBILE ════════ */
/* Mobile nav hamburger — hidden on desktop, shown <=1024px */
.nav-toggle-input { display: none; }
.nav-toggle { display: none; }

@media (max-width: 1024px) {
  .nav-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    cursor: pointer;
    margin-right: 0.5rem;
    flex-shrink: 0;
  }
  .nav-toggle-line {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--ink);
    margin: 0 auto;
    transition: transform 0.22s ease, opacity 0.18s ease;
  }

  .nav-toggle-input:checked ~ 
  .nav-toggle-input:checked + .nav-toggle .nav-toggle-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-toggle-input:checked + .nav-toggle .nav-toggle-line:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle-input:checked + .nav-toggle .nav-toggle-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }
  .hero { grid-template-columns: 1fr; gap: 3rem; }
  .hero-content { padding-right: 0; }
  .section-head-2col { grid-template-columns: 1fr; gap: 1rem; }
  .section-num { padding-top: 0; }
  .rooms-grid { grid-template-columns: 1fr 1fr; }
  .room.featured { grid-row: auto; }
  .plans-grid { grid-template-columns: 1fr 1fr; }
  .exclusions-grid { grid-template-columns: 1fr 1fr; }
  .system-cards { grid-template-columns: 1fr; }
  .areas-grid { grid-template-columns: 1fr; gap: 2rem; }
  
}
@media (max-width: 640px) {

